# Construction Estimating Agent — Configuration Template
# Copy to .env and fill in your API keys

# API Keys (Required)
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Models (Optional - defaults provided)
EMBEDDING_MODEL=text-embedding-3-small
AGENT_MODEL=claude-3-5-sonnet-20241022

# Database (Optional)
DATABASE_URL=sqlite:///./construction_agent.db

# File Handling (Optional)
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=5

# Embedding Settings (Optional)
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CACHE_ENABLED=true

# Outlier Detection (Optional)
OUTLIER_ZSCORE_THRESHOLD=2.0
OUTLIER_IQR_MULTIPLIER=1.5

# Logging (Optional)
LOG_LEVEL=INFO
LOG_FILE=logs/construction_agent.log

# Development (Optional)
DEBUG=false
VERBOSE=false
