# API Keys
OPENAI_API_KEY=sk_test_your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
AGENT_MODEL=claude-3-5-sonnet-20241022

# Database
DATABASE_URL=sqlite:///./construction_agent.db

# File Upload Limits
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=5

# Embedding Settings
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CACHE_ENABLED=true

# Outlier Detection
OUTLIER_ZSCORE_THRESHOLD=2.0
OUTLIER_IQR_MULTIPLIER=1.5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/construction_agent.log

# Development
DEBUG=false
VERBOSE=false
