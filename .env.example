# Construction Estimating Agent — Configuration Template
# Copy to .env and fill in your API keys

# ============================================================================
# REQUIRED: API Keys
# ============================================================================

# OpenAI API key for embeddings
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-openai-key-here

# Anthropic API key for Claude agent
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here

# ============================================================================
# OPTIONAL: Model Configuration
# ============================================================================

# OpenAI embedding model (used for semantic search)
# Options: text-embedding-3-small (1536 dims, $0.02/1M tokens)
#          text-embedding-3-large (3072 dims, $0.13/1M tokens)
# Default: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude model (used for agent reasoning)
# Options: claude-sonnet-4-6 (fast, balanced)
#          claude-opus-4-7 (most capable)
# Default: claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6

# ============================================================================
# OPTIONAL: Storage Configuration
# ============================================================================

# SQLite database file path for vector storage
# Default: construction_agent.db (current directory)
# Example: /tmp/construction_agent.db or ./data/vectors.db
# DATABASE_PATH=construction_agent.db

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================

# Logging level: DEBUG (verbose), INFO (standard), WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Optional log file path. If not set, logs only to console.
# Example: logs/construction_agent.log
# LOG_FILE=logs/construction_agent.log

